{
  "profileId": "generic-maa-log",
  "session_id": "replace-with-your-session-id",
  "inputs": [
    {
      "path": "/absolute/path/to/your/logs-or-zip",
      "kind": "folder",
      "focus": {
        "keywords": ["AutoCollectStart"],
        "started_after": "2026-04-16 14:50:00"
      }
    }
  ],
  "queries": {
    "task_overview": {},
    "raw_lines": {
      "task_id": 1,
      "keywords": ["Error", "timeout"],
      "limit": 20
    }
  }
}
