{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "corpus-catalog/v1"
    },
    "corpora": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "rootPaths": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "includeGlobs": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "tags": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "rootPaths",
          "includeGlobs",
          "tags"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "apiVersion",
    "corpora"
  ],
  "additionalProperties": false,
  "$id": "https://maa-diagnostic-expert/contracts/corpus-catalog.schema.json",
  "title": "CorpusCatalog",
  "description": "Builtin local corpus catalog exposed by @maa-diagnostic-expert/core runtime."
}
