{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "runtime/v1"
    },
    "runtimeName": {
      "type": "string",
      "minLength": 1
    },
    "runtimeVersion": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adapters": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "builtinProfileIds": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "builtinCorpusIds": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contracts": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "filename": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "schemaId": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "name",
          "filename",
          "title",
          "description",
          "schemaId"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "apiVersion",
    "runtimeName",
    "runtimeVersion",
    "commands",
    "adapters",
    "builtinProfileIds",
    "builtinCorpusIds",
    "contracts"
  ],
  "additionalProperties": false,
  "$id": "https://maa-diagnostic-expert/contracts/runtime-info.schema.json",
  "title": "RuntimeInfo",
  "description": "Runtime discovery contract exposed by @maa-diagnostic-expert/core."
}
