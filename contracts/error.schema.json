{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "error/v1"
    },
    "code": {
      "type": "string",
      "enum": [
        "validation_error",
        "io_error",
        "profile_not_found",
        "adapter_error",
        "runtime_error",
        "unsupported_input",
        "internal_error"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "retryable": {
      "default": false,
      "type": "boolean"
    },
    "details": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "default": [],
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                }
              ]
            }
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "path",
          "message"
        ],
        "additionalProperties": false
      }
    },
    "meta": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "apiVersion",
    "code",
    "message",
    "retryable",
    "details",
    "meta"
  ],
  "additionalProperties": false,
  "$id": "https://maa-diagnostic-expert/contracts/error.schema.json",
  "title": "CoreError",
  "description": "Structured error contract emitted by @maa-diagnostic-expert/core runtime."
}
