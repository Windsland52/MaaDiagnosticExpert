{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "retrieval-result/v1"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "corpusIds": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hits": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "corpus": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "section": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number"
          },
          "snippet": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "metadata": {
            "default": {},
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "id",
          "corpus",
          "path",
          "score",
          "snippet",
          "tags",
          "metadata"
        ],
        "additionalProperties": false
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "corpusCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "fileCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "hitCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "corpusCount",
        "fileCount",
        "hitCount"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "apiVersion",
    "query",
    "corpusIds",
    "hits",
    "stats"
  ],
  "additionalProperties": false,
  "$id": "https://maa-diagnostic-expert/contracts/corpus-search-result.schema.json",
  "title": "CorpusSearchResult",
  "description": "Output contract for deterministic local corpus search."
}
