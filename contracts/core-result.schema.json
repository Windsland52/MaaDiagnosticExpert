{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "core/v1"
    },
    "profileId": {
      "default": null,
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "rawToolResults": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "diagnosticMeta": {
      "type": "object",
      "properties": {
        "observations": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "sourceTool": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "default": "info",
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "error"
                ]
              },
              "payload": {
                "default": {},
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              },
              "tags": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "references": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": [
                        "log_line",
                        "source_file",
                        "image",
                        "url",
                        "tool_result",
                        "archive_entry",
                        "doc_chunk"
                      ]
                    },
                    "locator": {
                      "type": "string",
                      "minLength": 1
                    },
                    "label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "sourceTool": {
                      "type": "string",
                      "minLength": 1
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "line": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "column": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "meta": {
                      "default": {},
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {}
                    }
                  },
                  "required": [
                    "kind",
                    "locator",
                    "meta"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "id",
              "kind",
              "summary",
              "severity",
              "payload",
              "tags",
              "references"
            ],
            "additionalProperties": false
          }
        },
        "findings": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "default": "likely",
                "type": "string",
                "enum": [
                  "confirmed",
                  "likely",
                  "possible",
                  "rejected"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "basisObservationIds": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "supportingReferences": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": [
                        "log_line",
                        "source_file",
                        "image",
                        "url",
                        "tool_result",
                        "archive_entry",
                        "doc_chunk"
                      ]
                    },
                    "locator": {
                      "type": "string",
                      "minLength": 1
                    },
                    "label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "sourceTool": {
                      "type": "string",
                      "minLength": 1
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "line": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "column": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "meta": {
                      "default": {},
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {}
                    }
                  },
                  "required": [
                    "kind",
                    "locator",
                    "meta"
                  ],
                  "additionalProperties": false
                }
              },
              "gaps": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "tags": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "id",
              "kind",
              "statement",
              "status",
              "confidence",
              "basisObservationIds",
              "supportingReferences",
              "gaps",
              "tags"
            ],
            "additionalProperties": false
          }
        },
        "retrievalHits": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "corpus": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "section": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "score": {
                "type": "number"
              },
              "snippet": {
                "type": "string",
                "minLength": 1
              },
              "tags": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "metadata": {
                "default": {},
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "required": [
              "id",
              "corpus",
              "path",
              "score",
              "snippet",
              "tags",
              "metadata"
            ],
            "additionalProperties": false
          }
        },
        "profileHints": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "recommended_tool",
                  "recommended_corpus",
                  "recommended_query",
                  "report_template",
                  "note"
                ]
              },
              "value": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kind",
              "value"
            ],
            "additionalProperties": false
          }
        },
        "missingEvidence": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "suggestedActions": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "id",
              "description",
              "priority",
              "suggestedActions"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "observations",
        "findings",
        "retrievalHits",
        "profileHints",
        "missingEvidence"
      ],
      "additionalProperties": false
    },
    "report": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "sections": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "content": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "title",
              "content"
            ],
            "additionalProperties": false
          }
        },
        "body": {
          "default": "",
          "type": "string"
        }
      },
      "required": [
        "format",
        "sections",
        "body"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "apiVersion",
    "profileId",
    "rawToolResults",
    "diagnosticMeta"
  ],
  "additionalProperties": false,
  "$id": "https://maa-diagnostic-expert/contracts/core-result.schema.json",
  "title": "CoreResult",
  "description": "Structured output contract emitted by @maa-diagnostic-expert/core."
}
