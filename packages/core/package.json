{
  "name": "@maa-diagnostic-expert/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "maa-diagnostic-core": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:contracts": "node --import tsx ./src/contracts/generate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --maxWorkers=1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@windsland52/maa-log-parser": "^3.0.1",
    "@windsland52/maa-log-tools": "^3.0.1",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.2",
    "jsonc-parser": "^3.3.1",
    "pino": "^9.9.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.11"
  }
}
